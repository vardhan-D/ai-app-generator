generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppRecord {
  id        String   @id @default(cuid())
  entity    String
  userId    String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
  @@index([userId])
  @@index([entity, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   @default("info")
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityName String
  message    String
  metadata   Json
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityName])
}